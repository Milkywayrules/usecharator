{
  "name": "charator",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "ci:smoke": "bun scripts/ci-smoke.ts",
    "e2e": "playwright test --config e2e/playwright.config.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@charator/db": "workspace:*",
    "@playwright/test": "^1.61.1",
    "turbo": "^2.10.5",
    "typescript": "^5.9.3",
    "ultracite": "^7.9.4"
  }
}
