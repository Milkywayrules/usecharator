# Dummy prod-like env for local docker compose rehearsal — NOT for production.
# Generate fresh secrets before any real deploy.

NODE_ENV=production

POSTGRES_USER=charator
POSTGRES_PASSWORD=rehearsal-postgres-password
POSTGRES_DB=charator
DATABASE_URL=postgresql://charator:rehearsal-postgres-password@postgres:5432/charator

BETTER_AUTH_SECRET=01234567890123456789012345678901
BETTER_AUTH_URL=https://charator.dioilham.com
GITHUB_CLIENT_ID=rehearsal-github-client-id
GITHUB_CLIENT_SECRET=rehearsal-github-client-secret

KEY_ENCRYPTION_MASTER_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

PAYMENT_WEBHOOK_SECRET=rehearsal-payment-webhook-secret-value
PAYMENT_PROVIDER=mock
MOCK_BILLING_ENABLED=false
WEB_APP_URL=https://charator.dioilham.com

R2_ACCOUNT_ID=rehearsal-account-id
R2_ACCESS_KEY_ID=rehearsal-access-key
R2_SECRET_ACCESS_KEY=rehearsal-secret-key
R2_BUCKET=charator-rehearsal
R2_ENDPOINT=https://rehearsal-account-id.r2.cloudflarestorage.com
