    {
      "description": "a provider capabilities request",
      "providerStates": [
        {
          "name": "provider capabilities are configured"
        }
      ],
      "request": {
        "headers": {
          "Accept": "application/json"
        },
        "method": "GET",
        "path": "/api/v1/providers/capabilities"
      },
      "response": {
        "body": {
          "presets": [
            {
              "id": "anime-fast",
              "label": "Anime fast"
            }
          ],
          "providers": [
            {
              "label": "OpenRouter",
              "provider": "openrouter"
            }
          ]
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.presets": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
