# Chara Tor — local development defaults
# Production secrets are injected via Doppler on the VPS (Coolify).

# Database (local docker-compose postgres)
DATABASE_URL=postgresql://charator:charator@localhost:5432/charator
POSTGRES_USER=charator
POSTGRES_PASSWORD=charator
POSTGRES_DB=charator
POSTGRES_PORT=5432

# API
PORT=3001
NODE_ENV=development

# Web — Umami analytics (optional; script omitted when unset)
NEXT_PUBLIC_UMAMI_SRC=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# Auth (Better Auth + GitHub OAuth)
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Public API base URL (Traefik routes /api to the api service)
BETTER_AUTH_URL=http://localhost:3001
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# BYOK provider key encryption (32-byte key, base64)
# Generate: openssl rand -base64 32
KEY_ENCRYPTION_MASTER_KEY=

# Cloudflare R2 (S3-compatible object storage for generated images)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Optional custom endpoint; defaults to https://{R2_ACCOUNT_ID}.r2.cloudflarestorage.com
R2_ENDPOINT=

# Async provider webhooks (optional shared secrets for inbound verification)
FAL_WEBHOOK_SECRET=
REPLICATE_WEBHOOK_SECRET=

# Billing (mock provider by default — swap for Stripe/Polar later)
PAYMENT_PROVIDER=mock
# Required in production — generate: openssl rand -hex 32
PAYMENT_WEBHOOK_SECRET=
# Public web origin for checkout redirect URLs (defaults to http://localhost:3000)
WEB_APP_URL=http://localhost:3000
# Mock-only billing helpers (POST /api/billing/mock/complete); auto-enabled outside production
MOCK_BILLING_ENABLED=

# Generation job lifecycle
GENERATION_JOB_TIMEOUT_MS=300000
GENERATION_POLL_INTERVAL_MS=15000
PRESIGNED_URL_TTL_SECONDS=900

# Rate limits (sliding window, per hour)
RATE_LIMIT_ANONYMOUS_PER_HOUR=10
RATE_LIMIT_AUTHENTICATED_PER_HOUR=60

# Telegram bot (notify-only — disabled unless token and webhook secret are set)
TELEGRAM_BOT_TOKEN=
# Optional fallback when the getMe lookup is unavailable
TELEGRAM_BOT_USERNAME=
# Shared secret checked against the X-Telegram-Bot-Api-Secret-Token header
TELEGRAM_WEBHOOK_SECRET=

# GitHub CLI — local agent harness only (fine-grained PAT scoped to this repo)
# Create at: https://github.com/settings/tokens?type=beta
# Copy to .env.local and set GH_TOKEN — never commit .env.local
# CI uses GitHub Actions secrets; production uses your secrets manager (Doppler, etc.)
GH_TOKEN=
GH_REPO=Milkywayrules/usecharator
