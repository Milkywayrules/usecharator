{
  "name": "@charator/mcp",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "charator-mcp": "./dist/index.js"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun --external @charator/shared --external @charator/spec",
    "start": "bun dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "test": "bun test"
  },
  "dependencies": {
    "@charator/shared": "workspace:*",
    "@charator/spec": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^5.9.3"
  }
}
